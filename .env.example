# AI Reliability Engine Environment Configuration
# Copy this file to .env and adjust the values as needed

# =============================================================================
# CORE RELIABILITY CONFIGURATION
# =============================================================================

# Maximum allowed latency for real-time grounding (in milliseconds)
# Default: 150.0 (updated for realistic production performance)
AI_RELIABILITY_MAX_LATENCY_MS=150

# Maximum number of sentences to evaluate in a single response
# Default: 10
AI_RELIABILITY_MAX_SENTENCES=10

# Maximum response length to process (in characters)
# Default: 5000
AI_RELIABILITY_MAX_RESPONSE_LENGTH=5000

# Grounding thresholds
# Default: 0.7
AI_RELIABILITY_SUPPORT_THRESHOLD=0.7

# Default: 0.85
AI_RELIABILITY_ALLOW_THRESHOLD=0.85

# Default: 0.65
AI_RELIABILITY_HEDGE_THRESHOLD=0.65

# =============================================================================
# SAFETY THRESHOLDS (Guardrails-style protection)
# =============================================================================

# Safety decision thresholds (conservative defaults)
# Default: 0.3 (below this = BLOCK)
AI_RELIABILITY_SAFETY_BLOCK_THRESHOLD=0.3

# Default: 0.6 (below this = HEDGE)
AI_RELIABILITY_SAFETY_HEDGE_THRESHOLD=0.6

# Default: 0.75 (above this = ALLOW with high grounding)
AI_RELIABILITY_SAFETY_ALLOW_THRESHOLD=0.75

# Default: 0.8 (minimum grounding for ALLOW decisions)
AI_RELIABILITY_SAFETY_MIN_GROUNDING_FOR_ALLOW=0.8

# Grounding scoring weights (should sum to 1.0)
# Default: 0.5
AI_RELIABILITY_SUPPORT_WEIGHT=0.5

# Default: 0.3
AI_RELIABILITY_COVERAGE_WEIGHT=0.3

# Default: 0.2
AI_RELIABILITY_AGREEMENT_WEIGHT=0.2

# =============================================================================
# EMBEDDING CONFIGURATION
# =============================================================================

# Name of the embedding model to use
# Default: sentence-transformers/all-MiniLM-L6-v2
AI_RELIABILITY_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Batch size for embedding computation
# Default: 32
AI_RELIABILITY_EMBEDDING_BATCH_SIZE=32

# Maximum sequence length for tokenization
# Default: 512
AI_RELIABILITY_EMBEDDING_MAX_SEQUENCE_LENGTH=512

# Cache TTL in seconds (how long to keep embeddings in cache)
# Default: 3600 (1 hour)
AI_RELIABILITY_CACHE_TTL_SECONDS=3600

# Maximum number of embeddings to cache in memory
# Default: 10000
AI_RELIABILITY_CACHE_MAX_SIZE=10000

# Redis URL for distributed caching (optional)
# If not set, will use in-memory caching only
# Example: redis://localhost:6379
# AI_RELIABILITY_REDIS_URL=redis://localhost:6379

# =============================================================================
# LOGGING AND MONITORING
# =============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# Default: INFO
AI_RELIABILITY_LOG_LEVEL=INFO

# Enable Prometheus metrics collection
# Default: true
AI_RELIABILITY_ENABLE_METRICS=true

# Port for Prometheus metrics endpoint
# Default: 9090
AI_RELIABILITY_METRICS_PORT=9090

# =============================================================================
# PERFORMANCE TUNING
# =============================================================================

# Number of worker threads for parallel processing
# Default: 4
AI_RELIABILITY_WORKER_THREADS=4

# Enable/disable performance profiling
# Default: false
AI_RELIABILITY_ENABLE_PROFILING=false

# =============================================================================
# DEVELOPMENT AND DEBUGGING
# =============================================================================

# Enable debug mode (additional logging and validation)
# Default: false
AI_RELIABILITY_DEBUG=false

# Enable detailed timing information in logs
# Default: false
AI_RELIABILITY_DETAILED_TIMING=false

# Cache warming on startup (comma-separated list of common texts)
# Optional: leave empty to disable
# AI_RELIABILITY_CACHE_WARMING_TEXTS="Hello world,How are you?,Thank you"

# =============================================================================
# PRODUCTION SETTINGS
# =============================================================================

# Enable graceful shutdown handling
# Default: true
AI_RELIABILITY_GRACEFUL_SHUTDOWN=true

# Shutdown timeout in seconds
# Default: 30
AI_RELIABILITY_SHUTDOWN_TIMEOUT=30

# Maximum concurrent evaluations
# Default: 100
AI_RELIABILITY_MAX_CONCURRENT_EVALUATIONS=100

# =============================================================================
# EXAMPLE PRODUCTION CONFIGURATIONS
# =============================================================================

# High-performance configuration (uncomment and use as needed)
# AI_RELIABILITY_MAX_LATENCY_MS=100    # Aggressive target
# AI_RELIABILITY_EMBEDDING_BATCH_SIZE=64
# AI_RELIABILITY_CACHE_MAX_SIZE=50000
# AI_RELIABILITY_WORKER_THREADS=8

# High-safety configuration (uncomment and use as needed)
# AI_RELIABILITY_SAFETY_BLOCK_THRESHOLD=0.4     # More conservative
# AI_RELIABILITY_SAFETY_HEDGE_THRESHOLD=0.7     # More conservative
# AI_RELIABILITY_SAFETY_ALLOW_THRESHOLD=0.85    # Higher bar for ALLOW
# AI_RELIABILITY_SAFETY_MIN_GROUNDING_FOR_ALLOW=0.9  # Stricter grounding

# High-accuracy configuration (uncomment and use as needed)
# AI_RELIABILITY_SUPPORT_THRESHOLD=0.8
# AI_RELIABILITY_ALLOW_THRESHOLD=0.9
# AI_RELIABILITY_EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2

# Development configuration (uncomment and use as needed)
# AI_RELIABILITY_DEBUG=true
# AI_RELIABILITY_DETAILED_TIMING=true
# AI_RELIABILITY_LOG_LEVEL=DEBUG
# AI_RELIABILITY_ENABLE_PROFILING=true
